<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/badge_accent"
                    android:layout_marginEnd="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_launcher_foreground"
                        app:tint="@color/bg" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textAppearance="@style/Text.Display"
                    android:textSize="26sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/subtitle"
                android:textAppearance="@style/Text.Body" />
        </LinearLayout>

        <!-- Background & Reliability -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Background &amp; Reliability"
                    android:textAppearance="@style/Text.SectionLabel"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Active EQ modes run as foreground services with a persistent notification, which Android won't kill on its own. Some phone makers (MIUI, ColorOS, and similar) still aggressively stop background apps regardless — exempting this app from battery optimization prevents that."
                    android:textAppearance="@style/Text.Body"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/buttonBatteryExemption"
                    style="@style/Button.Tonal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Disable Battery Optimization for This App" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sound signature presets -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sound Signature"
                    android:textAppearance="@style/Text.SectionLabel"
                    android:layout_marginBottom="12dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:clipToPadding="false">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupPresets"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:chipSpacingHorizontal="8dp"
                        app:singleSelection="true"
                        app:selectionRequired="true" />
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/textPresetDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textAppearance="@style/Text.Body"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Manual EQ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manual EQ"
                    android:textAppearance="@style/Text.SectionLabel"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:id="@+id/bandSliderContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Test player -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Test Player"
                    android:textAppearance="@style/Text.SectionLabel"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:text="Pick a local audio file to hear the EQ applied in real time through your connected earbuds."
                    android:textAppearance="@style/Text.Body"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/textNowPlaying"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No file loaded"
                    android:textAppearance="@style/Text.Readout"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/buttonPickFile"
                        style="@style/Button.Tonal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Choose File" />

                    <Button
                        android:id="@+id/buttonPlayPause"
                        style="@style/Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Play"
                        android:enabled="false" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Root access -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Root Access"
                        android:textAppearance="@style/Text.SectionLabel" />

                    <View
                        android:id="@+id/dotRootStatus"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_indicator" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textRootStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:text="Checking for root…"
                    android:textAppearance="@style/Text.Body"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/buttonRootGrant"
                    style="@style/Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Grant Capture Permission (Root)"
                    android:enabled="false" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchGlobalMix"
                    style="@style/Switch.EarbudsEQ"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Use Global Mix EQ instead"
                    android:textAppearance="@style/Text.Body"
                    android:textColor="@color/text_primary"
                    android:enabled="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="@style/Text.Body"
                    android:textSize="11sp"
                    android:text="Global Mix attaches the EQ straight to the system output — lower latency, no consent popup, works even with apps that block capture. Reliability varies by device; if it doesn't seem to change the sound, switch this off and use System-Wide EQ below instead." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- System-wide EQ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="System-Wide EQ"
                        android:textAppearance="@style/Text.SectionLabel" />

                    <View
                        android:id="@+id/dotSystemEqStatus"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_indicator" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textShizukuStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:text="Checking Shizuku…"
                    android:textAppearance="@style/Text.Body"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/buttonShizukuAction"
                        style="@style/Button.Tonal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Set up" />

                    <Button
                        android:id="@+id/buttonToggleSystemEq"
                        style="@style/Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Enable"
                        android:enabled="false" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Body"
                    android:textSize="11sp"
                    android:text="Some apps (notably Spotify) can block audio capture on their end — outside this app's control without root." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:paddingHorizontal="4dp"
            android:textAppearance="@style/Text.Body"
            android:textSize="11sp"
            android:text="@string/system_hook_note" />

    </LinearLayout>
</ScrollView>
