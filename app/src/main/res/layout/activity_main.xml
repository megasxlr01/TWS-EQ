<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/badge_accent"
                    android:layout_marginEnd="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_launcher_foreground"
                        app:tint="@color/bg" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textAppearance="@style/Text.Display"
                    android:textSize="26sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/subtitle"
                android:textAppearance="@style/Text.Body" />
        </LinearLayout>

        <!-- Equalizer -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Equalizer"
                        android:textAppearance="@style/Text.Display"
                        android:textSize="20sp" />

                    <ImageButton
                        android:id="@+id/buttonEqMenu"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_more_vert"
                        android:contentDescription="More options" />
                </LinearLayout>

                <!-- Master enable row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <View
                        android:id="@+id/dotRootStatus"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/dot_indicator" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Equalizer"
                        android:textAppearance="@style/Text.Body"
                        android:textColor="@color/text_primary" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchMasterEq"
                        style="@style/Switch.EarbudsEQ"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:enabled="false" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textRootStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="Checking for root…"
                    android:textAppearance="@style/Text.Body"
                    android:textSize="11sp" />

                <!-- Curve graph -->
                <com.example.earbudseq.ui.EqualizerCurveView
                    android:id="@+id/eqCurveView"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="12dp" />

                <!-- Presets row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Presets"
                        android:textAppearance="@style/Text.Body"
                        android:textColor="@color/text_primary" />

                    <LinearLayout
                        android:id="@+id/buttonPresetDropdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/chip_background_static"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp">

                        <TextView
                            android:id="@+id/textSelectedPreset"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Custom"
                            android:textAppearance="@style/Text.Body"
                            android:textColor="@color/text_primary" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_dropdown" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Bass Boost / Loudness / Virtualizer dials -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/dial_card_background"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">

                        <com.example.earbudseq.ui.CircularDialView
                            android:id="@+id/dialBassBoost"
                            android:layout_width="72dp"
                            android:layout_height="72dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchBassBoost"
                            style="@style/Switch.EarbudsEQ"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:scaleX="0.8"
                            android:scaleY="0.8" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Bass Boost"
                            android:textAppearance="@style/Text.Body"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/dial_card_background"
                        android:padding="12dp"
                        android:layout_marginHorizontal="6dp">

                        <com.example.earbudseq.ui.CircularDialView
                            android:id="@+id/dialLoudness"
                            android:layout_width="72dp"
                            android:layout_height="72dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchLoudness"
                            style="@style/Switch.EarbudsEQ"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:scaleX="0.8"
                            android:scaleY="0.8" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Loudness"
                            android:textAppearance="@style/Text.Body"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/dial_card_background"
                        android:padding="12dp"
                        android:layout_marginStart="6dp">

                        <com.example.earbudseq.ui.CircularDialView
                            android:id="@+id/dialVirtualizer"
                            android:layout_width="72dp"
                            android:layout_height="72dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchVirtualizer"
                            style="@style/Switch.EarbudsEQ"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:scaleX="0.8"
                            android:scaleY="0.8" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Virtualizer"
                            android:textAppearance="@style/Text.Body"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Volume -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volume"
                    android:textAppearance="@style/Text.Body"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <SeekBar
                    android:id="@+id/seekBarVolume"
                    android:theme="@style/Theme.EarbudsEQ.SeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Background & Reliability -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Background &amp; Reliability"
                    android:textAppearance="@style/Text.SectionLabel"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="The equalizer runs as a foreground service with a persistent notification, which Android won't kill on its own. Some phone makers (MIUI, ColorOS, and similar) still aggressively stop background apps regardless — exempting this app from battery optimization prevents that."
                    android:textAppearance="@style/Text.Body"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/buttonBatteryExemption"
                    style="@style/Button.Tonal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Disable Battery Optimization for This App" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:paddingHorizontal="4dp"
            android:textAppearance="@style/Text.Body"
            android:textSize="11sp"
            android:text="@string/system_hook_note" />

    </LinearLayout>
</ScrollView>
